{
  "name": "@pi-harness/terminal-browser-search",
  "version": "1.0.0",
  "private": true,
  "description": "Browser Search extension for Pi Harness with multi-browser support",
  "main": "dist/index.js",
  "type": "commonjs",
  "bin": {
    "search": "bin/search.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build",
    "search:dry": "PI_SEARCH_DRY_RUN=1 node bin/search.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "pi": {
    "extensions": [
      "./src/pi-extension.ts"
    ]
  }
}
